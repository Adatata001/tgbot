# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini

# OpenRouter Configuration (preferred when set)
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_VISION_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=Trading Bot Pro

# Database Configuration (Supabase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# CoinGecko Configuration
COINGECKO_API_KEY=your_coingecko_api_key
COINGECKO_API_TIER=demo

# Admin Configuration
# ADMIN_IDS can contain numeric Telegram IDs. ADMIN_USERNAMES can contain usernames without @.
ADMIN_USERNAMES=admin_username

# Feature Flags
ENABLE_PREMIUM=true
FREE_ANALYSES_PER_DAY=5

# Uploads
VIDEO_FRAME_LIMIT=3

# Scheduled market announcements
MARKET_ANNOUNCEMENTS_ENABLED=false
MARKET_ANNOUNCEMENT_INTERVAL_MINUTES=360
MARKET_ANNOUNCEMENT_ASSETS=BTC,ETH,SOL
